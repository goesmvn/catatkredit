<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg-grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1B6CA8" />
      <stop offset="100%" stop-color="#0F4C75" />
    </linearGradient>
    <linearGradient id="check-grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#28a745" />
      <stop offset="100%" stop-color="#20c997" />
    </linearGradient>
  </defs>
  
  <!-- Background Rounded Rect -->
  <rect width="512" height="512" rx="112" fill="url(#bg-grad)" />
  
  <!-- Book / Ledger Base -->
  <path d="M160 112 h200 a32 32 0 0 1 32 32 v224 a32 32 0 0 1 -32 32 h-200 z" fill="#F8FAFC" />
  
  <!-- Book Binding / Spine -->
  <rect x="120" y="112" width="40" height="288" fill="#E2E8F0" />
  <path d="M140 112 v288" stroke="#CBD5E1" stroke-width="4" />
  
  <!-- Lines in the ledger -->
  <rect x="200" y="160" width="144" height="12" rx="6" fill="#CBD5E1" />
  <rect x="200" y="208" width="96" height="12" rx="6" fill="#CBD5E1" />
  <rect x="200" y="256" width="144" height="12" rx="6" fill="#CBD5E1" />
  <rect x="200" y="304" width="112" height="12" rx="6" fill="#CBD5E1" />
  
  <!-- Checkmark representing credit/success -->
  <path d="M224 336 l48 48 l112 -112" fill="none" stroke="url(#check-grad)" stroke-width="48" stroke-linecap="round" stroke-linejoin="round" />
</svg>
